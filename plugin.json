{
    "preload": "preload.js",
    "logo": "logo.jpg",
    "development": {
        "main": ""
    },
    "pluginSetting": {
        "single": true,
        "height": 0
    },
    "features": [
        {
            "code": "apkInstall",
            "explain": "apk安装",
            "cmds": [
                "apkt",
                {
                    "type": "regex",
                    "label": "apk链接安装",
                    "match": "/^http.*\\.apk$/"
                },
                {
                    "type": "img",
                    "label": "apk二维码安装"
                },
                {
                    "type": "files",
                    "label": "apk文件安装",
                    "fileType": "file",
                    "match": "/.apk$/",
                    "minLength": 1,
                    "maxLength": 1
                }
            ]
        }
    ]
}