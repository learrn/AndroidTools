{
    "preload": "preload.js",
    "logo": "logo.jpg",
    "development": {
        "main": ""
    },
    "pluginSetting": {
        "single": true,
        "height": 0
    },
    "features": [
        {
            "code": "apkInstall",
            "explain": "apk安装",
            "cmds": [
                {
                    "type": "regex",
                    "label": "apk链接安装",
                    "match": "/^http.*/"
                },
                {
                    "type": "img",
                    "label": "apk二维码安装"
                },
                {
                    "type": "files",
                    "label": "apk文件安装",
                    "fileType": "file",
                    "match": "/.apk$/",
                    "minLength": 1,
                    "maxLength": 1
                }
            ]
        },
        {
            "code": "apkPath",
            "explain": "apk安装环境",
            "cmds": [
                "APK环境清除",
                "ADB环境配置",
                "APK下载路径"
            ]
        },
        {
            "code": "adbTool",
            "explain": "常用adb命令",
            "cmds": [
                "设备截图",
                "设置代理",
                "清除代理",
                "APK代理端口设置",
                {
                    "type": "over",
                    "label": "adb input输入"
                }
            ]
        },
        {
            "code": "mcpService",
            "explain": "MCP service control",
            "cmds": [
                "start-mcp-service",
                "stop-mcp-service",
                "mcp-service-status"
            ]
        }
    ]
}
